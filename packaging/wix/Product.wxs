<?xml version="1.0" encoding="UTF-8"?>
<!--
  Definición del instalador MSI para "Asistente IA - La Vianda",
  usando WiX Toolset v3 (candle.exe + light.exe).

  Este archivo describe el producto, sus carpetas de instalación y sus
  accesos directos. La lista real de archivos a instalar (el contenido
  de dist/AsistenteIA generado por PyInstaller) se genera aparte con
  heat.exe en Files.wxs y se referencia aquí vía ComponentGroupRef.

  IMPORTANTE: UpgradeCode es fijo y NO debe cambiar entre versiones:
  es lo que permite que un instalador nuevo reemplace correctamente
  al anterior en vez de instalarse en paralelo.

  El atributo Version del Product (más abajo, hoy en 0.0.0.0) es un
  PLACEHOLDER: el workflow de GitHub Actions (y build_msi.ps1 para
  builds locales) generan una copia temporal de este archivo con la
  versión real ya sustituida (packaging/wix/obj/Product.generated.wxs)
  y compilan ESA copia — este archivo fuente nunca se modifica en el
  repositorio. No se pasa por -d de candle.exe porque esa vía tiene
  un problema real de parseo de argumentos con candle.exe (ver
  CNDL0103 en el historial del proyecto).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Asistente IA - La Vianda"
           Language="1033"
           Version="0.0.0.0"
           Manufacturer="La Vianda"
           UpgradeCode="755C98A5-480D-440E-A7F2-BC176B2DA485">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Instalador de Asistente IA - La Vianda"
             Manufacturer="La Vianda" />

    <MajorUpgrade DowngradeErrorMessage="Ya existe una versión más nueva de Asistente IA - La Vianda instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Asistente IA - La Vianda" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <Icon Id="AppIcon.ico" SourceFile="$(var.SourceDir)/AsistenteIA.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />

    <!-- ==============================================================
         Interfaz del instalador: Bienvenida -> Licencia -> Carpeta de
         instalación -> Progreso -> Finalizar. La pantalla de Finalizar
         incluye un checkbox "Iniciar Asistente IA - La Vianda" (tildado
         por defecto) que abre la app apenas termina la instalación,
         sin que el usuario tenga que buscarla manualmente.
         ============================================================== -->
    <WixVariable Id="WixUILicenseRtf" Value="packaging/wix/license.rtf" />
    <UIRef Id="WixUI_InstallDir" />
    <!-- Complemento casi siempre obligatorio junto a cualquier WixUI_*:
         define propiedades de texto (progreso, título de diálogo, etc.)
         que otros diálogos de la secuencia esperan encontrar. Omitirlo
         es una causa conocida del error 2819 en tiempo de instalación
         ("dialog control does not support the property"). -->
    <UIRef Id="WixUI_ErrorProgressText" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Iniciar Asistente IA - La Vianda" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- Ruta del ejecutable a abrir al finalizar: se arma con la carpeta
         de instalación (INSTALLFOLDER) + el nombre del .exe, en vez de
         referenciar el Id de archivo autogenerado por heat.exe (que no
         es predecible) -->
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]AsistenteIA.exe" />
    <CustomAction Id="LaunchApplication" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" />

    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed
      </Publish>
    </UI>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Asistente IA La Vianda" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Asistente IA - La Vianda" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <!-- Accesos directos: menú Inicio + escritorio + desinstalar -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="FA4AC0B4-7B4A-4641-80E7-D3666B6C0AE5">
        <Shortcut Id="StartMenuShortcut"
                  Name="Asistente IA - La Vianda"
                  Description="Asistente IA de escritorio para La Vianda"
                  Target="[INSTALLFOLDER]AsistenteIA.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="Asistente IA - La Vianda"
                  Description="Asistente IA de escritorio para La Vianda"
                  Target="[INSTALLFOLDER]AsistenteIA.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="UninstallShortcut"
                  Name="Desinstalar Asistente IA - La Vianda"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]"
                  Description="Desinstala Asistente IA - La Vianda" />
        <RemoveFolder Id="CleanUpProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                        Key="Software\LaVianda\AsistenteIA"
                        Name="installed"
                        Type="integer"
                        Value="1"
                        KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Product>
</Wix>
