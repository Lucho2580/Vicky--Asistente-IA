<?xml version="1.0" encoding="UTF-8"?>
<!--
  Definición del instalador MSI para "Asistente IA - La Vianda",
  usando WiX Toolset v3 (candle.exe + light.exe).

  IMPORTANTE - CODIFICACIÓN: este archivo debe guardarse como UTF-8
  CON BOM (marca de orden de bytes, los 3 bytes EF BB BF al inicio).
  Sin el BOM, candle.exe puede no detectar correctamente que el
  archivo es UTF-8 pese a decirlo en la cabecera XML, y termina
  interpretando mal los caracteres acentuados ("versión", "más", etc.)
  — eso produce el error LGHT0311 ("characters that are not available
  in the specified database code page") al enlazar con light.exe. Si
  editás este archivo con un editor que no preserva el BOM (algunos lo
  quitan al guardar), hay que volver a agregarlo.

  Este archivo describe el producto, sus carpetas de instalación y sus
  accesos directos. La lista real de archivos a instalar (el contenido
  de dist/AsistenteIA generado por PyInstaller) se genera aparte con
  heat.exe en Files.wxs y se referencia aquí vía ComponentGroupRef.

  IMPORTANTE: UpgradeCode es fijo y NO debe cambiar entre versiones:
  es lo que permite que un instalador nuevo reemplace correctamente
  al anterior en vez de instalarse en paralelo.

  El atributo Version del Product (más abajo, hoy en 0.0.0.0) es un
  PLACEHOLDER: el workflow de GitHub Actions (y build_msi.ps1 para
  builds locales) generan una copia temporal de este archivo con la
  versión real ya sustituida (packaging/wix/obj/Product.generated.wxs)
  y compilan ESA copia — este archivo fuente nunca se modifica en el
  repositorio. No se pasa por -d de candle.exe porque esa vía tiene
  un problema real de parseo de argumentos con candle.exe (ver
  CNDL0103 en el historial del proyecto).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Asistente IA - La Vianda"
           Language="1033"
           Version="0.0.0.0"
           Manufacturer="La Vianda"
           UpgradeCode="755C98A5-480D-440E-A7F2-BC176B2DA485">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Instalador de Asistente IA - La Vianda"
             Manufacturer="La Vianda" />

    <MajorUpgrade DowngradeErrorMessage="Ya existe una version mas nueva de Asistente IA - La Vianda instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Asistente IA - La Vianda" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <Icon Id="AppIcon.ico" SourceFile="$(var.SourceDir)/AsistenteIA.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />

    <!-- Sin interfaz personalizada: instalación estándar de Windows
         Installer (progreso + finalizar por defecto). Se probó agregar
         un asistente con licencia/elegir carpeta (WixUI_InstallDir) y
         un checkbox de "abrir al finalizar", pero ambas variantes
         producían el error 2819 en una instalación real, y no se pudo
         verificar la causa exacta sin acceso a Windows/WiX Toolset real
         para depurarlo (el entorno de desarrollo solo tiene una
         reimplementación en Linux que no soporta esa parte de WiX). Se
         revirtió para no seguir bloqueando la instalación.

         Para retomarlo con una causa real (no adivinada), generar un
         log detallado de una instalación que falle:
             msiexec /i AsistenteIA-Setup.msi /l*v install.log
         y buscar la línea con "2819" — ahí Windows Installer sí anota
         el Dialog/Control/Property exactos involucrados. -->

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Asistente IA La Vianda" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Asistente IA - La Vianda" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <!-- Accesos directos: menú Inicio + escritorio + desinstalar -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="FA4AC0B4-7B4A-4641-80E7-D3666B6C0AE5">
        <Shortcut Id="StartMenuShortcut"
                  Name="Asistente IA - La Vianda"
                  Description="Asistente IA de escritorio para La Vianda"
                  Target="[INSTALLFOLDER]AsistenteIA.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="Asistente IA - La Vianda"
                  Description="Asistente IA de escritorio para La Vianda"
                  Target="[INSTALLFOLDER]AsistenteIA.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <Shortcut Id="UninstallShortcut"
                  Name="Desinstalar Asistente IA - La Vianda"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]"
                  Description="Desinstala Asistente IA - La Vianda" />
        <RemoveFolder Id="CleanUpProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                        Key="Software\LaVianda\AsistenteIA"
                        Name="installed"
                        Type="integer"
                        Value="1"
                        KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Product>
</Wix>
